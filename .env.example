# ========================================
# Telegram Bot Configuration
# ========================================
# Token gerado via @BotFather
TELEGRAM_BOT_TOKEN=

# ========================================
# OpenWeather API Configuration
# ========================================
# Gere sua chave em https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ========================================
# Webhook Configuration
# ========================================
# URL pública do seu servidor (ex: https://xxxx.ngrok.io)
WEBHOOK_URL=

# ========================================
# Google Gemini API Configuration
# ========================================
# Gere sua chave no Google AI Studio:
# https://aistudio.google.com/api-keys
# Utilize esta variável para configurar a credencial no N8N.
GOOGLE_API_KEY=