    {
      "parameters": {
        "chatId": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "text": "={{\n  (() => {\n    const fallback = $json.reply;\n\n    // texto vindo do Gemini\n    const raw = $json.content?.parts?.[0]?.text;\n    if (!raw) return fallback;\n\n    // remove cerca ```json ... ``` e espaços\n    const cleaned = String(raw)\n      .trim()\n      .replace(/^```json\\s*/i, '')\n      .replace(/```$/i, '')\n      .trim();\n\n    try {\n      const obj = JSON.parse(cleaned);\n      return obj.message ?? fallback;\n    } catch (e) {\n      // se não for JSON válido, manda o texto limpo mesmo\n      return cleaned || fallback;\n    }\n  })()\n}}",
        "additionalFields": {
          "appendAttribution": false
        }
