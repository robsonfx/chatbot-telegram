    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "888df763-068f-434f-a6fc-d63a70f9e6e2",
              "name": "queue",
              "value": "={{\n  (() => {\n    const raw = $json.message?.text ?? \"\";\n\n    // remove espaços duplicados e trim\n    let s = String(raw).trim().replace(/\\s+/g, \" \");\n\n    // remove acentos\n    s = s.normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\");\n\n    // pega apenas a cidade (antes da vírgula)\n    const city = s.split(\",\")[0].trim();\n\n    // retorna com espaço normal\n    return `${city},BR`;\n  })()\n}}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
