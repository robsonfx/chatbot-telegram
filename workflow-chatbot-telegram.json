              "name": "reply",
              "value": "={{\n  (() => {\n    const message = $json.body?.message;\n\n    if (message === \"city not found\") {\n      return \"❌ Cidade não encontrada. Digite no formato: Cidade, UF (ex: Macapá, AP).\";\n    }\n\n    return \"❌ Não foi possível consultar o clima no momento. Tente novamente.\";\n  })()\n}}",
              "type": "string"
            }
          ]
        },
