              "id": "51873989-0616-419c-8489-ddd1a4fe6662",
              "name": "reply",
              "value": "={{\n  (() => {\n    const city = $json.body?.name ?? \"Cidade\";\n    const temp = Number($json.body?.main?.temp);\n\n    if (Number.isNaN(temp)) {\n      return `❌ Não consegui obter a temperatura de ${city}.`;\n    }\n\n    const show = Number.isInteger(temp) ? temp : Math.round(temp);\n\n    return `🌤️ A temperatura em ${city} é de ${show}°C.`;\n  })()\n}}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
